# LLM API 配置（h3i平台）
MODEL_API_BASE=http://model.ic.h3i.buaa.edu.cn
MODEL_API_KEY=your_api_key_here
DEFAULT_MODEL=Qwen2.5-72B-Instruct

# LLM API 配置（llm.py 使用）
LLM_API_URL=http://model.ic.h3i.buaa.edu.cn/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL_NAME=Qwen2.5-72B-Instruct

# KnG 服务地址
KNG_BASE_URL=http://127.0.0.1:50001

# 服务器端口
PORT=8000

# 数据库路径
DATABASE_URL=sqlite:///./writing_assistant.db

# OpenAI API 密钥（如需使用 OpenAI 模型）
OPENAI_API_KEY=your-openai-api-key